Private Sub btnImportarFacturas_Click()
Dim Reg As Integer, TotReg As Integer
Dim Ruta As String, nomFile As String, XML As Variant
Dim Comprobante, Emisor, Receptor, Conceptos, Impuestos, Complemento
    'Limpieza de Informacion
    If Range("B6") <> "" Then
        TotReg = Range("B5").End(xlDown).Row
        Range("A6:Z" & TotReg).ClearContents
    End If
    Reg = 6
    'Lectura de Facturas
    Ruta = ActiveWorkbook.Path & "\Facturas\"
    nomFile = Dir(Ruta & "*.xml", vbArchive)
    While Len(nomFile) > 0
        DoEvents
        'Lectura de XML
        XML = CreateObject("Scripting.FileSystemObject").GetFile(Ruta & nomFile).OpenAsTextStream(1, 0).ReadAll
        Comprobante = DecodeXML(XML, "cfdi:Comprobante")
        Emisor = DecodeXML(XML, "cfdi:Emisor")
        Receptor = DecodeXML(XML, "cfdi:Receptor")
        Conceptos = DecodeXML(XML, "cfdi:Conceptos")
        Impuestos = DecodeXML(XML, "cfdi:Impuestos")
        Complemento = DecodeXML(XML, "cfdi:Complemento")
        'Generacion de Registro
        Cells(Reg, 2) = DecodeNodo(Complemento, "Calle")
        Cells(Reg, 3) = DecodeNodo(Complemento, "PolizaRespCivil")
        Cells(Reg, 4) = dFecha(DecodeNodo(Comprobante, "Fecha"))
        Cells(Reg, 5) = DecodeNodo(Complemento, "FechaTimbrado")
        Cells(Reg, 6) = DecodeNodo(Comprobante, "Serie") & Format(DecodeNodo(Comprobante, "Folio"), "000000")
        Cells(Reg, 7) = DecodeNodo(Comprobante, " SubTotal")
        Cells(Reg, 8) = DecodeNodo(Impuestos, "TotalImpuestosTrasladados")
        Cells(Reg, 9) = DecodeNodo(Impuestos, "TotalImpuestosRetenidos")
        Cells(Reg, 10) = DecodeNodo(Comprobante, " Total")
        Cells(Reg, 11) = DecodeNodo(Complemento, "UUID")
        Set XML = Nothing
        Cells(Reg, 1) = BuscarEstacion(Cells(Reg, 2))
        Reg = Reg + 1
        nomFile = Dir()
    Wend
    MsgBox "Importacion Exitosa ..."
End Sub

Private Function DecodeXML(ByVal XML As String, ByVal Nodo As String) As String
Dim PosIni As Integer, PosFin As Integer
    DecodeXML = ""
    On Error Resume Next
    PosIni = InStr(XML, "<" & Nodo)
    PosFin = InStr(XML, "</" & Nodo)
    If Nodo = "cfdi:Impuestos" Then
        XML = Mid(XML, PosFin + Len(Nodo))
        PosIni = InStr(XML, "<" & Nodo)
        PosFin = InStr(XML, "</" & Nodo)
    End If
    If PosIni > 0 And PosFin > 0 Then
        If InStr(Nodo, "Comprobante") > 0 Then
            PosFin = InStr(XML, "<cfdi:Emisor")
            DecodeXML = Mid(XML, PosIni, PosFin - PosIni) & "</" & Nodo & ">"
        Else
            DecodeXML = Mid(XML, PosIni, PosFin - PosIni + Len(Nodo) + 3)
        End If
    ElseIf PosIni > 0 And PosFin = 0 Then
        XML = Mid(XML, PosIni)
        PosFin = InStr(XML, "/>")
        DecodeXML = Mid(XML, 1, PosFin + 3)
    End If
End Function

Private Function DecodeNodo(ByVal XML As String, ByVal Nodo As String) As String
Dim Cadena As String
    DecodeNodo = ""
    On Error Resume Next
    If InStr(XML, Nodo) > 0 Then
        Cadena = Mid(XML, InStr(XML, Nodo) + Len(Nodo) + 2)
        DecodeNodo = Mid(Cadena, 1, InStr(Cadena, """") - 1)
    End If
End Function

Private Function dFecha(ByVal fechaTimbre As String) As Date
    dFecha = Mid(fechaTimbre, 1, 10)
End Function

Private Function BuscarEstacion(ByVal Calle As String) As String
Dim Reg As Integer, TotReg As Integer, tEst As Worksheet
    BuscarEstacion = ""
    Set tEst = Sheets("CatEstaciones")
    TotReg = tEst.Range("B1").End(xlDown).Row
    For Reg = 2 To TotReg
        DoEvents
        If Calle = tEst.Range("A" & Reg) Then
            BuscarEstacion = tEst.Range("B" & Reg)
            Exit For
        End If
    Next Reg
    Set tEst = Nothing
End Function

