            Buffer = Buffer & Chr(13) & Chr(10) & "AM " & Range("K" & Reg) & " "
            Buffer = Buffer & Chr(13) & Chr(10) & "AD " & Range("K" & Reg) & " "
            'Abono Proveedor (Sepsa)
            TipoMov = "1"
            Cuenta = Prv
            Importe = ftSpace(Format(Range("J" & Reg).Value, "###0.0#"), 20, "I")
            Buffer = Buffer & Chr(13) & Chr(10) & "M  " & Cuenta & " " & Referencia & " " & TipoMov & " " & Importe & " " & Diario & " " & ImporteME & " " & Concepto & " " & ftSpace(" ", 4, "D") & " "
