        'Cerrar Poliza
        nFile = FreeFile
        Archivo = ActiveWorkbook.Path & "\Poliza_Sepsa_" & Format(Sheets("Generales").Range("C3"), "DD_MM_YYYY") & ".txt"
        Open Archivo For Output As #nFile
        Print #nFile, Buffer
        Close #nFile
    End If
    Range("A6").Select
    MsgBox "Poliza Generada ..."
End Sub

Private Function BuscarCuenta(ByVal Estacion As String) As String
Dim Reg As Integer, TotReg As Integer, tEst As Worksheet
    BuscarCuenta = ""
    Set tEst = Sheets("CatEstaciones")
    TotReg = tEst.Range("B1").End(xlDown).Row
    For Reg = 2 To TotReg
        DoEvents
        If Estacion = tEst.Range("B" & Reg) Then
            BuscarCuenta = tEst.Range("C" & Reg)
            Exit For
        End If
    Next Reg
    Set tEst = Nothing
End Function

Private Function ftGuion(ByVal Rubro As String) As String
    ftGuion = Replace(Rubro, "-", "")
End Function

Private Function ftSpace(ByVal Valor As String, ByVal Size As Integer, ByVal Hori As String) As String
Dim x As Integer
    If Hori = "" Then Hori = "D"
    If Hori = "I" Then
        ftSpace = Valor & String(Size, " ")
        ftSpace = Mid(ftSpace, 1, Size)
    ElseIf Hori = "D" Then
        ftSpace = String(Size, " ") & Valor
        ftSpace = Mid(ftSpace, Len(ftSpace) - Size + 1, 500)
    End If
End Function
